# Telegram bot
BOT_TOKEN=PUT_YOUR_TELEGRAM_BOT_TOKEN_HERE
ALLOWED_USER_ID=123456789

# Services inside assistant
FILE_SERVICE_URL=http://127.0.0.1:8787
PHONE_WORKER_URL=http://127.0.0.1:8788

# Phone Connect local (not an ngrok) URL (use https:// if SSL certs are generated)
PHONE_CONNECT_LOCAL_URL=https://127.0.0.1:3000

# Phone Connect URL (what you open on mobile if you want to use it)
PHONE_CONNECT_URL=https://your.ngrok-free.dev/

# Password for Phone Connect auth (APP_PASSWORD in .env Phone Connect)
APP_PASSWORD=YOUR_APP_PASSWORD

# Initial message for session init (used by phone_worker /init)
PHONE_INIT_MESSAGE=init session

# Should launcher try to start Antigravity itself (true/false)
LAUNCH_ANTIGRAVITY=true
AUTO_INIT_SESSION=true

# Antigravity project path (default project, used as fallback)
ANTIGRAVITY_PROJECT_DIR=/your_path/antigravity/projects/your_project_name

# Base directory containing all Antigravity projects.
# The bot scans this folder to discover available projects.
PROJECTS_BASE_DIR=/your_path/antigravity/projects

# Phone Connect folder path
PHONE_CONNECT_DIR=/your_path/antigravity_phone_chat

# Background watcher interval (seconds) — how often to check for new
# messages when user works on desktop Antigravity
POLL_INTERVAL=10.0
BG_WATCH_INTERVAL=20.0

# systemd user service name (used by the bot to restart on project switch)
SYSTEMD_SERVICE_NAME=antigravity-assistant
